<?xml version="1.0" encoding="utf-8"?>
<!-- play mark: a play triangle foreshortened like the app's panorama tilt, given
     depth by an extruded side face, a light top edge and a very faint shadow. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- horizontal foreshortening (scaleX) fakes the panorama rotateY tilt -->
    <group
        android:pivotX="54"
        android:pivotY="54"
        android:scaleX="0.94">

        <!-- very subtle cast shadow (barely there on the dark background) -->
        <path
            android:pathData="M47,39 L50,85 L86,62 Z"
            android:fillColor="#40000000" />

        <!-- extruded side face — the play button's thickness -->
        <path
            android:pathData="M44,35 L47,81 L83,58 Z"
            android:fillColor="#17567F" />

        <!-- front face -->
        <path
            android:pathData="M40,30 L43,76 L79,53 Z"
            android:fillColor="#3FB0F2" />

        <!-- top edge highlight -->
        <path
            android:pathData="M40,30 L79,53"
            android:strokeColor="#BCE9FF"
            android:strokeWidth="2"
            android:strokeLineCap="round" />
    </group>
</vector>
